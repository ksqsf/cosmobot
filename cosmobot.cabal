        Bot.AgentAudit.Types
        Bot.ChatLog.Record
        Bot.ChatLog.Types
        Bot.Core.Conversation
        Bot.Effect.AgentAudit
        Bot.Effect.ChatLog
        Bot.Effect.LLM
        Bot.Effect.Memory
        Bot.Effect.Scheduler
        Bot.Effect.Skills
