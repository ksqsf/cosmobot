executable cosmobot
    -- Import common warning flags.
    import:           warnings
                    , threaded
                    , rtsopts
                    , language
                    , app-deps
                    , bot-core-modules
                    , bot-chat-driver-modules
                    , bot-agent-modules

    -- .hs or .lhs file containing the Main module.
    main-is:          Main.hs

    -- Modules included in this executable, other than Main.
    other-modules:
        Bot.Agent.Config
        Bot.Chat.Driver
        Bot.Chat.Driver.Discord.Config
        Bot.Chat.Driver.Matrix.Config
        Bot.Chat.Driver.QQ.Config
        Bot.Chat.Driver.Telegram.Config
        Bot.Config
        Bot.Core.Route
        Bot.LLM.OpenAI
        Bot.Main
        Bot.Media.Interpreter
        Bot.Media.Object
        Bot.Media.S3
        Bot.Media.S3.Config
        Bot.RPC.Audit
        Bot.RPC.Client
        Bot.Handler.Admin
        Bot.Handler.Admin.Config
        Bot.Lifecycle
        Bot.Handler.Ask
        Bot.Handler.Ask.Config
        Bot.Handler.Audit
        Bot.Handler.Safebooru
        Bot.Handler.Scratchpad
        Bot.Handler.Saucenao.Config
        Bot.Handler.ShutUp
        Bot.Handler.ShutUp.Config
        Bot.Handler.Typing
        Bot.Handler.Typing.Typst
        Bot.Memory.Config
        Bot.RPC.Server
        Bot.Skills.Config
        Bot.Handler.Saucenao
        Bot.Util.Toml

    -- LANGUAGE extensions used by modules in this package.
    -- other-extensions:

    -- Other library packages from which modules are imported.
    build-depends:    log-base
                    , aeson-optics
                    , dotenv
                    , optparse-applicative
                    , websockets
                    , toml-parser

