cabal-version:      3.14
-- The cabal-version field refers to the version of the .cabal specification,
-- and can be different from the cabal-install (the tool) version and the
-- Cabal (the library) version you are using. As such, the Cabal (the library)
-- version used must be equal or greater than the version stated in this field.
-- Starting from the specification version 2.2, the cabal-version field must be
-- the first thing in the cabal file.

-- Initial package description 'cosmobot' generated by
-- 'cabal init'. For further documentation, see:
--   http://haskell.org/cabal/users-guide/
--
-- The name of the package.
name:               cosmobot

-- The package version.
-- See the Haskell package versioning policy (PVP) for standards
-- guiding when and how versions should be incremented.
-- https://pvp.haskell.org
-- PVP summary:     +-+------- breaking API changes
--                  | | +----- non-breaking API additions
--                  | | | +--- code changes with no API change
version:            0.1.0.0

-- A short (one-line) description of the package.
-- synopsis:

-- A longer description of the package.
-- description:

-- The license under which the package is released.
license:            NONE

-- The package author(s).
author:             ksqsf

-- An email address to which users can send suggestions, bug reports, and patches.
maintainer:         i@ksqsf.moe

-- A copyright notice.
-- copyright:
build-type:         Simple

-- Extra doc files to be distributed with the package, such as a CHANGELOG or a README.
extra-doc-files:    CHANGELOG.md

-- Extra source files to be distributed with the package, such as examples, or a tutorial module.
-- extra-source-files:

common warnings
    ghc-options: -Wall

common threaded
    ghc-options: -threaded

common language
    default-language: GHC2021
    default-extensions:
        DataKinds
        DeriveAnyClass
        DerivingVia
        DuplicateRecordFields
        LambdaCase
        NoFieldSelectors
        NoImplicitPrelude
        OverloadedRecordDot
        OverloadedStrings
        QuasiQuotes
        TypeFamilies
        BlockArguments

common app-deps
    build-depends:    base >=4.18.0.0
                    , relude
                    , text
                    , containers
                    , direct-sqlite
                    , directory
                    , filepath
                    , effectful
                    , log-effectful
                    , streaming
                    , transformers
                    , stm
                    , bytestring
                    , base64-bytestring
                    , aeson
                    , string-interpolate
                    , unix
                    , modern-uri
                    , req
                    , http-client
                    , http-client-tls
                    , optics
                    , time
                    , process
    hs-source-dirs:   app

common test-deps
    build-depends:    tasty
                    , tasty-hunit

executable cosmobot
    -- Import common warning flags.
    import:           warnings
                    , threaded
                    , language
                    , app-deps

    -- .hs or .lhs file containing the Main module.
    main-is:          Main.hs

    -- Modules included in this executable, other than Main.
    other-modules:
        Bot.Prelude
        Bot.Agent
        Bot.Agent.Tools
        Bot.Agent.Types
        Bot.Chat.Driver
        Bot.Config
        Bot.Core.Conversation
        Bot.Util.Html
        Bot.Util.Image
        Bot.Core.Message
        Bot.Memory
        Bot.Util.Multipart
        Bot.Core.ReplyBody
        Bot.Storage.SQLite
        Bot.Core.Filter
        Bot.Handler.Ask
        Bot.Handler.Scratchpad
        Bot.Handler.Typing
        Bot.Effect.Chat
        Bot.Effect.ChatLog
        Bot.Effect.Chat.QQ
        Bot.Effect.Chat.Telegram
        Bot.Effect.LLM
        Bot.Effect.Scheduler
        Bot.Handler.Saucenao

    -- LANGUAGE extensions used by modules in this package.
    -- other-extensions:

    -- Other library packages from which modules are imported.
    build-depends:    log-base
                    , aeson-optics
                    , dotenv
                    , websockets
                    , toml-parser

test-suite filter-spec
    import:           warnings
                    , language
                    , app-deps
                    , test-deps
    type:             exitcode-stdio-1.0
    main-is:          FilterSpec.hs
    other-modules:
        Bot.Prelude
        Bot.Core.Message
        Bot.Core.Filter
        Bot.Effect.Chat
        Bot.Core.ReplyBody
    hs-source-dirs:   test

test-suite scratchpad-spec
    import:           warnings
                    , language
                    , app-deps
                    , test-deps
    type:             exitcode-stdio-1.0
    main-is:          ScratchpadSpec.hs
    other-modules:
        Bot.Core.Filter
        Bot.Prelude
        Bot.Core.Message
        Bot.Effect.Chat
        Bot.Core.ReplyBody
        Bot.Storage.SQLite
        Bot.Handler.Scratchpad
    hs-source-dirs:   test

test-suite chat-platform-spec
    import:           warnings
                    , language
                    , app-deps
                    , test-deps
    type:             exitcode-stdio-1.0
    main-is:          ChatPlatformSpec.hs
    other-modules:
        Bot.Prelude
        Bot.Core.Message
        Bot.Effect.Chat
        Bot.Core.ReplyBody
        Bot.Effect.Chat.QQ
        Bot.Effect.Chat.Telegram
        Bot.Util.Multipart
    build-depends:    base64-bytestring
                    , http-client
                    , req
                    , websockets
    hs-source-dirs:   test

test-suite scheduler-spec
    import:           warnings
                    , language
                    , app-deps
                    , test-deps
    type:             exitcode-stdio-1.0
    main-is:          SchedulerSpec.hs
    other-modules:
        Bot.Prelude
        Bot.Core.Message
        Bot.Effect.Scheduler
    hs-source-dirs:   test

test-suite agent-spec
    import:           warnings
                    , threaded
                    , language
                    , app-deps
                    , test-deps
    type:             exitcode-stdio-1.0
    main-is:          AgentSpec.hs
    other-modules:
        Bot.Agent
        Bot.Agent.Tools
        Bot.Agent.Types
        Bot.Core.Conversation
        Bot.Effect.Chat
        Bot.Effect.ChatLog
        Bot.Effect.LLM
        Bot.Effect.Scheduler
        Bot.Util.Html
        Bot.Util.Image
        Bot.Core.Message
        Bot.Memory
        Bot.Prelude
        Bot.Core.ReplyBody
        Bot.Storage.SQLite
    build-depends:    http-client
                    , process
                    , req
    hs-source-dirs:   test

test-suite chat-log-spec
    import:           warnings
                    , language
                    , app-deps
                    , test-deps
    type:             exitcode-stdio-1.0
    main-is:          ChatLogSpec.hs
    other-modules:
        Bot.Effect.Chat
        Bot.Effect.ChatLog
        Bot.Core.Message
        Bot.Prelude
        Bot.Core.ReplyBody
        Bot.Storage.SQLite
    hs-source-dirs:   test
